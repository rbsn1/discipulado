# =============================================================
# Variáveis de Ambiente — Módulo de Discipulado
# =============================================================
# Copie este arquivo para .env.local e preencha os valores.
# Nunca comite o .env.local com valores reais.
# =============================================================

# Supabase (obrigatório)
# Encontre em: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Nunca exposto no navegador — usado apenas em Server Actions / Route Handlers
# Encontre em: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# URL da aplicação (usada em redirects e CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000
